# ============================================
# All AI Tool List — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend Email (Required for emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=AI Tool List <hello@allaitoollist.com>
RESEND_TEST_EMAIL=your-test@email.com

# Cron Job Security (Required for automation)
# Generate a strong random string: openssl rand -hex 32
CRON_SECRET=your-super-secret-cron-key

# IndexNow (Required for search indexing)
INDEXNOW_KEY=your-indexnow-key

# OpenAI (Required for AI auto-generator)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# LongChat (Optional - for blog generation)
LONGCHAT_API_KEY=ak_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Payments (Required for paid features)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_VERIFIED_BASIC=price_xxxxxxxxxxxxxx
STRIPE_PRICE_VERIFIED_PRO=price_xxxxxxxxxxxxxx
STRIPE_PRICE_VERIFIED_ENTERPRISE=price_xxxxxxxxxxxxxx
STRIPE_PRICE_API_PRO=price_xxxxxxxxxxxxxx
STRIPE_PRICE_API_ENTERPRISE=price_xxxxxxxxxxxxxx
STRIPE_PRICE_JOB_BASIC=price_xxxxxxxxxxxxxx
STRIPE_PRICE_JOB_FEATURED=price_xxxxxxxxxxxxxx

# Twitter/X Auto-Posting (Optional)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL
NEXT_PUBLIC_SITE_URL=https://allaitoollist.com

# Admin Credentials (Required - keep secret!)
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-strong-password-here
